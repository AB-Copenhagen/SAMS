generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Asset {
  id                 String      @id @default(cuid())
  title              String?
  description        String?
  eventName          String?
  eventDate          DateTime?
  location           String?
  objectKey          String      @unique
  contentHash        String?     @unique
  aiTagStatus        String      @default("pending")
  assetUrl           String
  fileType           String
  fileSize           Int
  uploaderEmail      String
  uploaderRole       String
  manualTagsJson     String?
  detectedTagsJson   String?
  wasbaiResponseJson String?
  gcvResponseJson    String?
  aiDescription      String?
  uploadedAt         DateTime    @default(now())
  category           String?
  exifJson           String?
  collectionId       String?
  collection         Collection? @relation(fields: [collectionId], references: [id])
  seasonId           String?
  season             Season?     @relation(fields: [seasonId], references: [id])
  ingestJob          IngestJob?
  faceTagStatus      String      @default("pending")
  faceTagAttempts    Int         @default(0)
  thumbnailKey       String?
  thumbnailStatus    String      @default("pending")
  thumbnailAttempts  Int         @default(0)
  playerTags         AssetPlayerTag[]
  sponsorTags        AssetSponsorTag[]
}

model AssetPlayerTag {
  id         String    @id @default(cuid())
  assetId    String
  asset      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  playerId   String
  player     Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  source     String
  confidence Float?
  status     String    @default("suggested")
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
  reviewedBy String?

  @@unique([assetId, playerId, source])
  @@index([playerId, status])
}

model AssetSponsorTag {
  id         String    @id @default(cuid())
  assetId    String
  asset      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  sponsorId  String
  sponsor    Sponsor   @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  source     String
  confidence Float?
  status     String    @default("suggested")
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
  reviewedBy String?

  @@unique([assetId, sponsorId, source])
  @@index([sponsorId, status])
}

model DeviceCredential {
  id         String      @id @default(cuid())
  name       String
  keyPrefix  String      @unique
  keyHash    String
  ownerEmail String
  role       String      @default("MEDIA")
  scopesJson String      @default("[\"ingest:write\"]")
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime    @default(now())
  ingestJobs IngestJob[]
}

model IngestJob {
  id             String            @id @default(cuid())
  deviceId       String?
  device         DeviceCredential? @relation(fields: [deviceId], references: [id])
  uploaderEmail  String
  uploaderRole   String
  channel        String
  fileName       String
  fileType       String
  fileSize       Int
  contentHash    String?
  objectKey      String            @unique
  uploadId       String?
  partSize       Int?
  partsTotal     Int?
  partsCompleted Int               @default(0)
  status         String            @default("pending")
  errorMessage   String?
  assetId        String?           @unique
  asset          Asset?            @relation(fields: [assetId], references: [id])
  metadataJson   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  completedAt    DateTime?

  @@index([status, updatedAt])
}

model Season {
  id          String       @id @default(cuid())
  name        String
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime     @default(now())
  assets      Asset[]
  collections Collection[]
  players     Player[]
}

model Player {
  id                String           @id @default(cuid())
  name              String
  number            Int?
  position          String?
  headshotUrl       String?
  active            Boolean          @default(true)
  team              String?
  seasonId          String?
  season            Season?          @relation(fields: [seasonId], references: [id])
  createdAt         DateTime         @default(now())
  faceEnrolledAt    DateTime?
  rekognitionFaceId String?
  assetTags         AssetPlayerTag[]
}

model Sponsor {
  id          String            @id @default(cuid())
  name        String
  logoUrl     String?
  tier        String?
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  aliasesJson String?
  assetTags   AssetSponsorTag[]
}

model Stadium {
  id          String       @id @default(cuid())
  name        String
  city        String?
  createdAt   DateTime     @default(now())
  collections Collection[]
}

model Collection {
  id        String    @id @default(cuid())
  name      String
  type      String    @default("game")
  date      DateTime?
  opponent  String?
  venue     String?
  coverUrl  String?
  createdAt DateTime  @default(now())
  seasonId  String?
  season    Season?   @relation(fields: [seasonId], references: [id])
  stadiumId String?
  stadium   Stadium?  @relation(fields: [stadiumId], references: [id])
  assets    Asset[]
}
