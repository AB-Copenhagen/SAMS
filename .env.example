# Copy this file to .env.local and fill in your values

# Descope authentication — https://console.descope.com
NEXT_PUBLIC_DESCOPE_PROJECT_ID=your-descope-project-id
DESCOPE_SERVICE_ACCOUNT_KEY=your-descope-service-account-key

# Wasabi Cloud Storage — https://console.wasabisys.com
WASABI_REGION=eu-central-1
WASABI_BUCKET=your-bucket-name
WASABI_ENDPOINT=https://s3.eu-central-1.wasabisys.com
WASABI_ACCESS_KEY_ID=your-wasabi-access-key-id
WASABI_SECRET_ACCESS_KEY=your-wasabi-secret-access-key

# Wasabi AiR — AI tagging (optional — leave blank to disable). Either a bearer token,
# or a dedicated IAM access key/secret pair (create via Wasabi console → AIR).
WASABI_AIR_API_TOKEN=
WASABI_AIR_ACCESS_KEY_ID=
WASABI_AIR_SECRET_ACCESS_KEY=

# Google Cloud Vision — AI tagging (optional — leave all blank to disable). Use ONE of:
#  1. GOOGLE_CLOUD_CREDENTIALS_JSON — a service account JSON, inlined as a single-line string
#  2. GCP_WIF_AUDIENCE (+ optionally GCP_SERVICE_ACCOUNT_EMAIL) — Workload Identity Federation via Vercel OIDC
#  3. Neither — falls back to Application Default Credentials (local dev only)
GOOGLE_CLOUD_CREDENTIALS_JSON=
GCP_WIF_AUDIENCE=
GCP_SERVICE_ACCOUNT_EMAIL=

# Turso hosted SQLite — https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name.aws-eu-west-1.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Prisma CLI only (not used at runtime — adapter connects via TURSO_*)
DATABASE_URL=file:./prisma/dev.db

# Upstash Redis — presigned-URL caching — https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Session signing — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-random-64-char-hex-secret

# AWS Rekognition — player face identification (separate, narrowly-scoped IAM credentials;
# recommend an EU region for GDPR data residency since face vectors are biometric data)
AWS_REKOGNITION_REGION=eu-west-1
AWS_REKOGNITION_ACCESS_KEY_ID=your-rekognition-access-key-id
AWS_REKOGNITION_SECRET_ACCESS_KEY=your-rekognition-secret-access-key
REKOGNITION_COLLECTION_ID=sams-players
REKOGNITION_AUTO_APPLY_THRESHOLD=97
REKOGNITION_SUGGEST_THRESHOLD=80
REKOGNITION_MAX_FACES_PER_IMAGE=15

# Protects the Vercel Cron endpoint from being invoked by anyone who finds the URL (optional —
# if unset, cron requests are trusted by default, which is fine since Vercel Cron calls are
# already only reachable from Vercel's own infrastructure)
CRON_SECRET=

# api-football.com — only needed for the fixture/match importer (optional)
API_FOOTBALL_KEY=
